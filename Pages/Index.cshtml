<script>
// AG Grid API stored OUTSIDE Alpine state.
// Alpine v3 deeply proxies all state objects via JavaScript Proxy.
// AG Grid's internal methods rely on correct `this` binding — storing the API
// inside Alpine state causes those bindings to break silently.
let _g = null;

// ─── Geographic view (Leaflet + OpenStreetMap — free, no API key) ────────────
let _map = null;
const _geoMarkers = [];
const _geoCache = (() => {
  try { return JSON.parse(sessionStorage.getItem('aim_geocache') || '{}'); } catch(e) { return {}; }
})();
const STATE_COORDS = {
  AL:[32.806671,-86.791130],AK:[61.370716,-152.404419],AZ:[33.729759,-111.431221],
  AR:[34.969704,-92.373123],CA:[36.116203,-119.681564],CO:[39.059811,-105.311104],
  CT:[41.597782,-72.755371],DE:[39.318523,-75.507141],FL:[27.766279,-81.686783],
  GA:[33.040619,-83.643074],HI:[21.094318,-157.498337],ID:[44.240459,-114.478828],
  IL:[40.349457,-88.986137],IN:[39.849426,-86.258278],IA:[42.011539,-93.210526],
  KS:[38.526600,-96.726486],KY:[37.668140,-84.670067],LA:[31.169960,-91.867805],
  ME:[44.693947,-69.381927],MD:[39.063946,-76.802101],MA:[42.230171,-71.530106],
  MI:[43.326618,-84.536095],MN:[45.694454,-93.900192],MS:[32.741646,-89.678696],
  MO:[38.456085,-92.288368],MT:[46.921925,-110.454353],NE:[41.125370,-98.268082],
  NV:[38.313515,-117.055374],NH:[43.452492,-71.563896],NJ:[40.298904,-74.521011],
  NM:[34.840515,-106.248482],NY:[42.165726,-74.948051],NC:[35.630066,-79.806419],
  ND:[47.528912,-99.784012],OH:[40.388783,-82.764915],OK:[35.565342,-96.928917],
  OR:[44.572021,-122.070938],PA:[40.590752,-77.209755],RI:[41.680893,-71.511780],
  SC:[33.856892,-80.945007],SD:[44.299782,-99.438828],TN:[35.747845,-86.692345],
  TX:[31.054487,-97.563461],UT:[40.150032,-111.862434],VT:[44.045876,-72.710686],
  VA:[37.769337,-78.169968],WA:[47.400902,-121.490494],WV:[38.491226,-80.954453],
  WI:[44.268543,-89.616508],WY:[42.755966,-107.302490],DC:[38.897438,-77.026817]
};

function aim() {
  return {
    loading: true,
    activeRisks: [],
    searchQuery: '',
    currentView: 'overview',
    rowCount: 0,
    selected: [],
    dv: null,
    dtab: 'overview',
    vendors: [],
    allVendors: [],
    geoState: null,
    geoCity: null,
    geoItems: [],
    geoLoading: false,
    geoStatus: '',
    _reportToastShown: false,

    // Sidebar tier counts — set once on init, never change (always show all-tier totals)
    kpi: { total:0, topCount:0, highCount:0, moderateCount:0, lowCount:0 },

    // KPI card values — update with each filter change
    view: { total:0, highRisk:0, products:0, unverified:0 },

    get healthScore() {
      if (!this.kpi.total) return 0;
      return Math.round(((this.kpi.moderateCount + this.kpi.lowCount) / this.kpi.total) * 100);
    },

    async init() {
      window.__aim = this;
      lucide.createIcons();
      await this.$nextTick();
      console.log('[AIM] init — DOM ready, creating grid');
      this._initGrid();
      console.log('[AIM] grid created, _g =', _g ? typeof _g : 'NULL');
      await this._load();
    },

    navTo(view) {
      this.currentView = view;
      if (view === 'overview')   { this.toggleRisk(''); }
      if (view === 'risk')       { this.toggleRisk(''); this.$nextTick(() => document.getElementById('vendor-grid')?.scrollIntoView({behavior:'smooth',block:'start'})); }
      if (view === 'products')   { this.toggleRisk(''); this.$nextTick(() => document.getElementById('vendor-grid')?.scrollIntoView({behavior:'smooth',block:'start'})); }
      if (view === 'geographic') { this.$nextTick(() => this._geoInit()); }
      if (view === 'reports' && !this._reportToastShown) { this.toast('Reports module coming soon', 'info'); this._reportToastShown = true; }
    },

    _initGrid() {
      const self = this;

      const rbR = p => {
        const v = p.value; if (!v) return '<span style="color:#475569">—</span>';
        return `<span class="rb rb-${v}">${v}</span>`;
      };
      const scoreR = p => {
        const v = p.value || 0;
        const pct = Math.min(100, Math.round(v * 1.8));
        return `<div class="sbar"><div class="sbar-track"><div class="sbar-fill" style="width:${pct}%"></div></div><span style="font-size:11px;color:#475569;min-width:22px;text-align:right">${v}</span></div>`;
      };
      const verR = p => p.value ? '<span style="color:#4ade80;font-size:13px">✓</span>' : '<span style="color:#f87171;font-size:13px">✗</span>';
      const actR = p => `<button onclick="window.__aim._openById(${p.data.VENDOR_ID})" style="font-size:11px;color:#60a5fa;background:rgba(59,130,246,.1);border:1px solid rgba(59,130,246,.25);padding:2px 10px;border-radius:6px;cursor:pointer;white-space:nowrap">Details</button>`;

      const cols = [
        { headerName:'Risk',         field:'SCORE_CATEGORY',  width:110, pinned:'left', cellRenderer:rbR, sortable:true, filter:true },
        { headerName:'Vendor',       field:'VENDOR_NAME',     flex:1, minWidth:155, sortable:true, filter:true, cellStyle:{fontWeight:500,color:'#e2e8f0'} },
        { headerName:'Product',      field:'PRODUCT_NAME',    flex:1, minWidth:135, sortable:true, filter:true, cellStyle:{color:'#94a3b8'} },
        { headerName:'Category',     field:'PRODUCT_GATEGORY',width:130, sortable:true, filter:true, cellStyle:{color:'#94a3b8',fontSize:'12px'} },
        { headerName:'Location', width:160, sortable:true,
          valueGetter: p => [p.data.CITY, p.data.STATE].filter(Boolean).join(', '),
          cellRenderer: p => {
            const primary = [p.data.CITY, p.data.STATE].filter(Boolean).join(', ') || '—';
            const extra   = (p.data.LOCATION_COUNT || 1) - 1;
            return extra > 0
              ? `<span style="color:#64748b;font-size:12px">${primary}</span> <span style="color:#60a5fa;font-size:10px">(+${extra} more)</span>`
              : `<span style="color:#64748b;font-size:12px">${primary}</span>`;
          }},
        { headerName:'Annual Sales', field:'ANNUAL_SALES',    width:130, sortable:true, type:'numericColumn',
          valueFormatter:p=>p.value?'$'+Number(p.value).toLocaleString(undefined,{maximumFractionDigits:0}):'—', cellStyle:{color:'#e2e8f0'} },
        { headerName:'Risk Score',   field:'TOTAL_SCORE',     width:145, sortable:true, cellRenderer:scoreR, cellStyle:{display:'flex',alignItems:'center'} },
        { headerName:'Verified',     field:'VERIFIED_COMPANY',width:82,  cellRenderer:verR, cellStyle:{display:'flex',alignItems:'center',justifyContent:'center'} },
        { headerName:'',             width:85, pinned:'right', cellRenderer:actR, sortable:false, cellStyle:{display:'flex',alignItems:'center'} }
      ];

      // Store outside Alpine state — avoids Proxy wrapping that breaks AG Grid's internal `this`
      _g = agGrid.createGrid(document.getElementById('vendor-grid'), {
        columnDefs: cols,
        rowData: [],
        rowSelection: 'multiple',
        suppressRowClickSelection: true,
        animateRows: true,
        suppressCellFocus: true,
        defaultColDef: { resizable:true, cellStyle:{display:'flex',alignItems:'center'} },
        onFirstDataRendered: p => { self.rowCount = p.api.getDisplayedRowCount(); p.api.sizeColumnsToFit(); },
        onSelectionChanged:  p => { self.selected = p.api.getSelectedRows(); },
        onRowClicked:        p => { if (p.event.target.tagName !== 'BUTTON') self.openDrawer(p.data); }
      });
    },

    async _load() {
      this.loading = true;
      try {
        console.log('[AIM] _load — fetching data...');
        const [vR, sR] = await Promise.all([
          fetch('/api/vendors?riskLevel='),
          fetch('/api/vendors/state-sales')
        ]);
        console.log('[AIM] fetch status:', vR.status, sR.status);
        const vd = await vR.json();
        const sd = await sR.json();

        const vendors = vd.items || [];
        const states  = (sd.items || []).filter(s => s.STATE && s.TOTAL_SALES > 0);
        console.log('[AIM] vendors:', vendors.length, '| states:', states.length);

        // Sidebar counts — derived from unique vendor+product pairs
        this.kpi.total         = vendors.length;
        this.kpi.topCount      = vendors.filter(v => v.SCORE_CATEGORY === 'TOP').length;
        this.kpi.highCount     = vendors.filter(v => v.SCORE_CATEGORY === 'HIGH').length;
        this.kpi.moderateCount = vendors.filter(v => v.SCORE_CATEGORY === 'MODERATE').length;
        this.kpi.lowCount      = vendors.filter(v => v.SCORE_CATEGORY === 'LOW').length;

        // KPI cards — full view on initial load
        this._applyView(vendors);

        // Grid
        console.log('[AIM] setting grid rowData, _g =', _g ? typeof _g : 'NULL');
        _g.setGridOption('rowData', vendors);
        this.allVendors = vendors;
        this.vendors = vendors;
        this.rowCount = vendors.length;
        // Confirm actual displayed rows (not just array length)
        await this.$nextTick();
        const actual = _g.getDisplayedRowCount();
        console.log('[AIM] grid rowData set — array:', vendors.length, '| displayed:', actual);

        this._donut(vendors);
        this._bars(states);
        this._sparks();

      } catch(e) {
        console.error(e);
        this.toast('Cannot reach server — is the .NET app running on port 5000?', 'error');
      } finally {
        this.loading = false;
        this.$nextTick(() => lucide.createIcons());
      }
    },

    // Compute and apply KPI card values for the current view
    _applyView(vendors) {
      this.view.total    = new Set(vendors.map(v => v.VENDOR_NAME)).size;
      this.view.products = new Set(vendors.map(v => v.PRODUCT_NAME)).size;
      this.view.highRisk = new Set(
        vendors.filter(v => v.SCORE_CATEGORY === 'TOP' || v.SCORE_CATEGORY === 'HIGH')
               .map(v => v.VENDOR_NAME)
      ).size;
      this.view.unverified = new Set(
        vendors.filter(v => !v.VERIFIED_COMPANY).map(v => v.VENDOR_NAME)
      ).size;
    },

    toggleRisk(level) {
      if (level === '') {
        // "All" clears every active selection
        this.activeRisks = [];
      } else {
        const idx = this.activeRisks.indexOf(level);
        this.activeRisks = idx === -1
          ? [...this.activeRisks, level]
          : this.activeRisks.filter(r => r !== level);
      }
      this._applyFilter();
    },

    _applyFilter() {
      const filtered = this.activeRisks.length === 0
        ? this.allVendors
        : this.allVendors.filter(v => this.activeRisks.includes(v.SCORE_CATEGORY));

      this.vendors = filtered;
      this._applyView(filtered);
      this._donut(filtered);
      this._bars(this._stateSalesFromVendors(filtered));

      _g.setGridOption('rowData', filtered);
      if (this.searchQuery) _g.setGridOption('quickFilterText', this.searchQuery);
      this.$nextTick(() => { this.rowCount = _g.getDisplayedRowCount(); });
    },

    // Aggregate annual sales by state from the vendors array.
    // Uses the primary STATE field on each vendor+product record.
    _stateSalesFromVendors(vendors) {
      const map = {};
      vendors.forEach(v => {
        if (!v.STATE) return;
        if (!map[v.STATE]) map[v.STATE] = { STATE: v.STATE, TOTAL_SALES: 0 };
        map[v.STATE].TOTAL_SALES += Number(v.ANNUAL_SALES) || 0;
      });
      return Object.values(map);
    },

    async refreshData() { await this._load(); this.toast('Data refreshed', 'success'); },

    applySearch() {
      if (!_g) return;
      _g.setGridOption('quickFilterText', this.searchQuery);
      this.rowCount = _g.getDisplayedRowCount();
    },

    focusSearch() { document.getElementById('grid-search')?.focus(); },

    _openById(id) {
      if (!_g) return;
      let found = null;
      _g.forEachNode(n => { if (n.data?.VENDOR_ID === id) found = n.data; });
      if (found) this.openDrawer(found);
    },

    openDrawer(vendor) {
      this.dv   = vendor;
      this.dtab = 'overview';
      document.getElementById('drawer').classList.add('open');
      document.getElementById('backdrop').classList.add('open');
      this.$nextTick(() => lucide.createIcons());
    },

    closeDrawer() {
      document.getElementById('drawer').classList.remove('open');
      document.getElementById('backdrop').classList.remove('open');
      setTimeout(() => { this.dv = null; }, 300);
    },

    act(type) {
      const name = this.dv?.VENDOR_NAME || 'Vendor';
      if (type === 'flag')   this.toast(name + ' flagged for takedown review', 'warn');
      if (type === 'watch')  this.toast(name + ' added to watchlist', 'info');
      if (type === 'safe')   { this.closeDrawer(); this.toast(name + ' marked as safe', 'success'); }
      if (type === 'export') {
        const a = document.createElement('a');
        a.href = 'data:application/json,' + encodeURIComponent(JSON.stringify(this.dv, null, 2));
        a.download = 'evidence-' + this.dv.VENDOR_ID + '.json';
        a.click();
        this.toast('Evidence bundle downloaded', 'success');
      }
    },

    exportCsv() {
      if (!_g) return;
      _g.exportDataAsCsv({ fileName:'aim-' + new Date().toISOString().slice(0,10) + '.csv' });
      this.toast('CSV exported', 'success');
    },

    bulkFlag() { this.toast(this.selected.length + ' vendors flagged for review', 'warn'); this.clearSel(); },
    clearSel() { this.selected = []; if (_g) _g.deselectAll(); },

    toast(msg, type = 'info') {
      const el = document.createElement('div');
      el.className = 'toast toast-' + type;
      el.textContent = msg;
      document.getElementById('toasts').appendChild(el);
      setTimeout(() => el.remove(), 3200);
    },

    _donut(src) {
      src = src || this.allVendors;
      const colorMap = { TOP:'#ef4444', HIGH:'#f97316', MODERATE:'#f59e0b', LOW:'#22c55e' };
      const allTiers = ['TOP','HIGH','MODERATE','LOW'].map(label => ({
        label,
        count: new Set(src.filter(v => v.SCORE_CATEGORY === label).map(v => v.VENDOR_NAME)).size,
        color: colorMap[label]
      }));
      const active = this.activeRisks.length > 0
        ? allTiers.filter(t => this.activeRisks.includes(t.label))
        : allTiers;
      const series = active.map(t => t.count);
      const labels = active.map(t => t.label);
      const colors = active.map(t => t.color);

      const opts = {
        chart:{ type:'donut', height:190, background:'transparent', toolbar:{show:false}, animations:{speed:500} },
        series, labels, colors,
        dataLabels:{ enabled:false },
        stroke:{ width:0 },
        legend:{ show:true, position:'right', fontSize:'11px', labels:{colors:'#94a3b8'}, markers:{size:6},
                 formatter:(lbl, op) => `${lbl} (${op.w.globals.series[op.seriesIndex]})` },
        plotOptions:{ pie:{ donut:{ size:'65%' } } },
        theme:{ mode:'dark' }
      };
      const el = document.getElementById('chart-donut');
      if (el._c) { el._c.updateOptions(opts); }
      else { setTimeout(() => { el._c = new ApexCharts(el, opts); el._c.render(); }, 50); }
    },

    _bars(states) {
      const top10 = [...states].sort((a,b) => b.TOTAL_SALES - a.TOTAL_SALES).slice(0,10);
      const opts = {
        chart:{ type:'bar', height:190, background:'transparent', toolbar:{show:false}, animations:{speed:500} },
        series:[{ name:'Annual Sales', data: top10.map(s => Math.round(Number(s.TOTAL_SALES))) }],
        xaxis:{ categories:top10.map(s=>s.STATE), labels:{style:{colors:'#475569',fontSize:'11px'}}, axisBorder:{color:'#1e293b'}, axisTicks:{show:false} },
        yaxis:{ labels:{style:{colors:'#475569',fontSize:'10px'}, formatter:v=>'$'+(v/1e6).toFixed(1)+'M'}, axisBorder:{show:false}, axisTicks:{show:false} },
        plotOptions:{ bar:{ columnWidth:'52%', borderRadius:3 } },
        colors:['#3b82f6'],
        fill:{ type:'gradient', gradient:{type:'vertical', opacityFrom:.85, opacityTo:.35} },
        grid:{ borderColor:'#1e293b', strokeDashArray:3, yaxis:{lines:{show:true}}, xaxis:{lines:{show:false}} },
        dataLabels:{ enabled:false },
        tooltip:{ theme:'dark', y:{ formatter:v=>'$'+v.toLocaleString() } },
        theme:{ mode:'dark' }
      };
      const el = document.getElementById('chart-states');
      if (el._c) {
        el._c.updateOptions({ xaxis:{ categories:opts.xaxis.categories } });
        el._c.updateSeries(opts.series);
      } else { setTimeout(() => { el._c = new ApexCharts(el, opts); el._c.render(); }, 50); }
    },

    _sparks() {
      const base = {
        chart:{ type:'area', background:'transparent', toolbar:{show:false}, sparkline:{enabled:true}, animations:{speed:500} },
        stroke:{ curve:'smooth', width:1.5 },
        fill:{ type:'gradient', gradient:{opacityFrom:.4, opacityTo:0} },
        tooltip:{ enabled:false },
        theme:{ mode:'dark' }
      };
      const trend = (val, up) => Array.from({length:12}, (_,i) => {
        const n = Math.max(1, Math.round(val * .08));
        const d = up ? i * val * .007 : -i * val * .004;
        return Math.max(1, Math.round(val + d + (Math.random() > .5 ? n : -n)));
      });
      const mk = (id, data, color) => {
        const el = document.getElementById(id); if (!el) return;
        const opts = { ...base, series:[{data}], colors:[color] };
        if (el._c) { el._c.updateSeries([{data}]); }
        else { setTimeout(() => { el._c = new ApexCharts(el, opts); el._c.render(); }, 50); }
      };
      mk('sp-total',      trend(this.kpi.total || 100,  true),  '#3b82f6');
      mk('sp-high',       trend((this.kpi.topCount + this.kpi.highCount) || 10, false), '#ef4444');
      mk('sp-products',   trend(this.view.products || 50, true),  '#a855f7');
      mk('sp-unverified', trend(this.view.unverified || 20, false), '#f59e0b');
    },

    async _geoInit() {
      this.geoStatus  = 'Initializing map…';
      this.geoLoading = true;
      try {
        await this.$nextTick();
        await new Promise(r => setTimeout(r, 50)); // let browser finish painting the container
        if (!_map) {
          // Leaflet map with CartoDB Dark tiles — free, no key needed
          _map = L.map('geo-map', {
            center: [39.5, -98.35], zoom: 4, minZoom: 3,
            zoomControl: true, attributionControl: true
          });
          L.tileLayer('https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png', {
            attribution: '&copy; <a href="https://www.openstreetmap.org/copyright" target="_blank">OpenStreetMap</a> &copy; <a href="https://carto.com/attributions" target="_blank">CARTO</a>',
            subdomains: 'abcd', maxZoom: 19
          }).addTo(_map);
        }
        // Always re-measure after x-show makes the container visible
        _map.invalidateSize();
        this._geoShowStates();
      } catch(e) {
        console.error('[GEO]', e);
        this.toast('Map failed to load', 'error');
      } finally {
        this.geoLoading = false;
        this.geoStatus  = '';
      }
    },

    _geoShowStates() {
      this.geoState = null;
      this.geoCity  = null;
      _geoMarkers.forEach(m => _map.removeLayer(m));
      _geoMarkers.length = 0;

      const sd = {};
      // Each vendor+product record may appear in multiple states via LOCATIONS_CSV.
      // Expand the pipe-separated STATE~CITY pairs to count appearances per state.
      this.vendors.forEach(v => {
        const states = [...new Set(
          (v.LOCATIONS_CSV || '').split('|').filter(Boolean)
            .map(l => l.split('~')[0]?.trim().toUpperCase()).filter(Boolean)
        )];
        // Fall back to v.STATE for records not yet scored
        if (!states.length && v.STATE) states.push(v.STATE.trim().toUpperCase());
        states.forEach(s => {
          if (!sd[s]) sd[s] = {state:s, total:0, highRisk:0};
          sd[s].total++;
          if (v.SCORE_CATEGORY === 'TOP' || v.SCORE_CATEGORY === 'HIGH') sd[s].highRisk++;
        });
      });

      Object.values(sd).forEach(d => {
        const c = STATE_COORDS[d.state]; if (!c) return;
        const pct = d.total ? d.highRisk / d.total : 0;
        const col = pct > .5 ? '#ef4444' : pct > .3 ? '#f97316' : pct > .1 ? '#f59e0b' : '#22c55e';
        const sz  = Math.max(32, Math.min(60, 20 + Math.sqrt(d.total) * 2.2)) | 0;
        const m = L.marker([c[0], c[1]], {
          icon: this._geoIcon(d.total, col, sz), title: d.state, zIndexOffset: sz
        }).addTo(_map);
        m.on('click', () => this._geoClickState(d));
        _geoMarkers.push(m);
      });

      this.geoItems = Object.values(sd).sort((a,b) => b.total - a.total).map(d => ({
        type:'state', name:d.state, count:d.total, highRisk:d.highRisk
      }));
      _map.invalidateSize();
      _map.setView([39.5, -98.35], 4);
    },

    async _geoClickState(sd) {
      this.geoState = sd.state;
      this.geoCity  = null;
      this.geoLoading = true;
      _geoMarkers.forEach(m => _map.removeLayer(m));
      _geoMarkers.length = 0;

      try {
        // Build city data from LOCATIONS_CSV — each vendor+product record may
        // appear in multiple cities within this state.
        const cityMap = {};
        this.vendors.forEach(v => {
          const locs = (v.LOCATIONS_CSV || '').split('|').filter(Boolean);
          const citiesInState = [...new Set(
            locs.map(l => {
              const [s, c] = l.split('~');
              return s?.trim().toUpperCase() === sd.state ? c?.trim() : null;
            }).filter(Boolean)
          )];
          // Fall back to v.CITY if this record has no LOCATIONS_CSV yet
          if (!citiesInState.length && v.STATE?.trim().toUpperCase() === sd.state && v.CITY) {
            citiesInState.push(v.CITY.trim());
          }
          citiesInState.forEach(c => {
            if (!cityMap[c]) cityMap[c] = {city:c, state:sd.state, total:0, highRisk:0, vendors:[]};
            cityMap[c].total++;
            if (v.SCORE_CATEGORY === 'TOP' || v.SCORE_CATEGORY === 'HIGH') cityMap[c].highRisk++;
            cityMap[c].vendors.push(v);
          });
        });

        const cities = Object.values(cityMap);
        const latLngs = [];

        // Geocode each city via Nominatim (OSM) — rate limit 1 req/sec, cache in sessionStorage
        for (let i = 0; i < cities.length; i++) {
          const cd  = cities[i];
          const key = `${cd.city},${cd.state}`;
          this.geoStatus = `Geocoding ${i + 1} / ${cities.length}: ${cd.city}`;

          if (!_geoCache[key]) {
            try {
              const url = `https://nominatim.openstreetmap.org/search?q=${encodeURIComponent(cd.city + ', ' + cd.state + ', USA')}&format=json&limit=1`;
              const r = await fetch(url, {headers:{'Accept-Language':'en'}});
              const d = await r.json();
              if (d?.[0]) _geoCache[key] = {lat: +d[0].lat, lng: +d[0].lon};
            } catch(e) {}
            // Nominatim requires ≤ 1 req/sec
            await new Promise(r => setTimeout(r, 1100));
          }

          // Add marker immediately as we get each city's coords
          const pos = _geoCache[key];
          if (!pos) continue;
          latLngs.push([pos.lat, pos.lng]);
          const pct = cd.total ? cd.highRisk / cd.total : 0;
          const col = pct > .5 ? '#ef4444' : pct > .3 ? '#f97316' : pct > .1 ? '#f59e0b' : '#22c55e';
          const sz  = Math.max(28, Math.min(52, 16 + Math.sqrt(cd.total) * 3.5)) | 0;
          const m = L.marker([pos.lat, pos.lng], {
            icon: this._geoIcon(cd.total, col, sz), title: cd.city, zIndexOffset: sz
          }).addTo(_map);
          m.on('click', () => this._geoClickCity(cd));
          _geoMarkers.push(m);
        }

        try { sessionStorage.setItem('aim_geocache', JSON.stringify(_geoCache)); } catch(e) {}

        if (latLngs.length > 0) {
          _map.fitBounds(L.latLngBounds(latLngs), {padding: [60, 60]});
        } else {
          const c = STATE_COORDS[sd.state];
          if (c) _map.setView([c[0], c[1]], 7);
        }

        this.geoItems = cities.sort((a,b) => b.total - a.total).map(c => ({
          type:'city', name:c.city, state:c.state, count:c.total, highRisk:c.highRisk, vendors:c.vendors
        }));
      } finally {
        this.geoLoading = false;
        this.geoStatus  = '';
      }
    },

    _geoClickCity(cd) {
      this.geoCity = cd.city;
      const pos = _geoCache[`${cd.city},${cd.state}`];
      if (pos) _map.setView([pos.lat, pos.lng], 11);

      const ORDER = ['TOP','HIGH','MODERATE','LOW'];

      // Deduplicate: the same vendor+product record may have been pushed to
      // cd.vendors more than once if it appears in multiple cities in this state.
      const seen = new Set();
      const unique = (cd.vendors || []).filter(v => {
        const k = v.VENDOR_NAME + '|' + v.PRODUCT_NAME;
        if (seen.has(k)) return false;
        seen.add(k); return true;
      });

      this.geoItems = unique
        .sort((a, b) => ORDER.indexOf(a.SCORE_CATEGORY) - ORDER.indexOf(b.SCORE_CATEGORY))
        .map(v => {
          // Build "TX: Dallas, Houston • FL: Miami" from LOCATIONS_CSV
          const byState = {};
          (v.LOCATIONS_CSV || '').split('|').filter(Boolean).forEach(l => {
            const [s, c] = l.split('~');
            if (!s || !c) return;
            if (!byState[s]) byState[s] = [];
            byState[s].push(c);
          });
          const locationStr = Object.entries(byState)
            .sort(([a], [b]) => a.localeCompare(b))
            .map(([s, cs]) => `${s}: ${cs.sort().join(', ')}`)
            .join(' • ') || (v.STATE ? `${v.STATE}: ${v.CITY}` : '');
          return {type:'product', name:v.PRODUCT_NAME, vendor:v.VENDOR_NAME, risk:v.SCORE_CATEGORY, locationStr, record:v};
        });
    },

    _geoZoomOut() {
      if (this.geoCity) {
        const sv = this.vendors.filter(v => v.STATE?.trim().toUpperCase() === this.geoState);
        this._geoClickState({
          state:    this.geoState,
          total:    sv.length,
          highRisk: sv.filter(v => v.SCORE_CATEGORY==='TOP'||v.SCORE_CATEGORY==='HIGH').length
        });
      } else {
        this._geoShowStates();
      }
    },

    // Returns a Leaflet DivIcon — a circular SVG bubble with vendor count
    _geoIcon(count, color, size) {
      const fs    = size > 40 ? 13 : size > 28 ? 11 : 9;
      const label = count > 9999 ? (count/1000|0)+'k' : String(count);
      const html  = `<div style="width:${size}px;height:${size}px;border-radius:50%;background:${color};opacity:.88;border:1.5px solid rgba(255,255,255,.22);display:flex;align-items:center;justify-content:center;color:#fff;font-weight:700;font-size:${fs}px;font-family:Inter,ui-sans-serif,system-ui,sans-serif;box-sizing:border-box;pointer-events:auto">${label}</div>`;
      return L.divIcon({html, className:'', iconSize:[size,size], iconAnchor:[size/2,size/2]});
    }
  };
}
</script>

</body>
</html>
