@page
@{
    Layout = null;
    if (!User.IsInRole("Admin")) { Response.Redirect("/"); return; }
}
<!DOCTYPE html>
<html lang="en" class="dark">
<head>
  <meta charset="UTF-8" />
  <title>AIM — Bulk Import</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.13.9/dist/cdn.min.js"></script>
  <style> body{background:#070b16;color:#e2e8f0;font-family:ui-sans-serif,system-ui,sans-serif} </style>
</head>
<body x-data="bulkImport()">
  <div class="max-w-5xl mx-auto p-6">
    <div class="flex items-center justify-between mb-5">
      <div>
        <h1 class="text-xl font-semibold">Bulk CSV Import</h1>
        <p class="text-xs text-slate-500">Preview and validate before committing. Historical loads land as <span class="font-mono">Acknowledged</span>.</p>
      </div>
      <a href="/" class="text-blue-400 text-xs hover:underline">← Dashboard</a>
    </div>

    <div class="bg-slate-900 border border-slate-800 rounded-lg p-4 mb-5">
      <form @@submit.prevent="preview()" class="flex items-center gap-3">
        <input type="file" accept=".csv" @@change="file = $event.target.files[0]" class="text-xs" />
        <button type="submit" :disabled="!file || loading"
          class="bg-blue-600 hover:bg-blue-500 disabled:bg-slate-700 rounded-md px-3 py-1.5 text-xs text-white">Preview</button>
        <span class="text-xs text-slate-500" x-show="loading">Parsing…</span>
      </form>
    </div>

    <div x-show="result" class="bg-slate-900 border border-slate-800 rounded-lg p-4">
      <div class="flex items-center justify-between mb-3">
        <div class="text-sm">
          <span x-text="result?.totalRows"></span> rows ·
          <span class="text-green-400" x-text="result?.validRows"></span> valid ·
          <span class="text-red-400" x-text="result?.errorRows"></span> errors
        </div>
        <button @@click="commit()" :disabled="!result?.validRows || result?.errorRows"
          class="bg-green-600 hover:bg-green-500 disabled:bg-slate-700 rounded-md px-3 py-1.5 text-xs text-white">Commit</button>
      </div>
      <table class="w-full text-xs">
        <thead class="text-slate-500 uppercase text-[10px] tracking-widest">
          <tr><th class="text-left p-1.5">Row</th><th class="text-left p-1.5">BSA ID</th><th class="text-left p-1.5">Subject</th><th class="text-right p-1.5">Amount</th><th class="text-left p-1.5">Risk</th><th class="text-left p-1.5">Errors</th></tr>
        </thead>
        <tbody>
          <template x-for="r in (result?.sample || [])" :key="r.rowNumber">
            <tr class="border-t border-slate-800" :class="r.errors.length ? 'bg-red-950/30' : ''">
              <td class="p-1.5" x-text="r.rowNumber"></td>
              <td class="p-1.5" x-text="r.parsed?.bsaId || '—'"></td>
              <td class="p-1.5" x-text="r.parsed?.subjectName || '—'"></td>
              <td class="p-1.5 text-right" x-text="r.parsed?.amountTotal ?? ''"></td>
              <td class="p-1.5" x-text="r.parsed?.riskLevel || ''"></td>
              <td class="p-1.5 text-red-400" x-text="r.errors.join('; ')"></td>
            </tr>
          </template>
        </tbody>
      </table>
    </div>

    <div x-show="committed" class="mt-4 p-3 rounded-md bg-green-950/30 border border-green-900 text-green-300 text-xs">
      Committed batch <span class="font-mono" x-text="committed?.batchId"></span>,
      inserted <span x-text="committed?.inserted"></span> rows.
    </div>
  </div>

<script>
  function bulkImport() {
    return {
      file: null,
      result: null,
      loading: false,
      committed: null,
      async preview() {
        if (!this.file) return;
        this.loading = true;
        const fd = new FormData();
        fd.append('file', this.file);
        const r = await fetch('/api/bsa-reports/import/preview', { method:'POST', body: fd });
        this.result = r.ok ? await r.json() : null;
        this.loading = false;
      },
      async commit() {
        if (!this.result?.uploadId) return;
        const r = await fetch('/api/bsa-reports/import/commit?uploadId=' + this.result.uploadId, { method:'POST' });
        this.committed = r.ok ? await r.json() : null;
      }
    };
  }
</script>
</body>
</html>
