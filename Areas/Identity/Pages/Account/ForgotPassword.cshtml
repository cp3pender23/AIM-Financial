@page
@{ Layout = null; }
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Forgot Password - AIM</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
        body {
            font-family: ui-sans-serif, system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
            background: #0a1628 url('/images/background.svg') no-repeat center center;
            background-size: cover;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            padding: 1rem;
        }
        .card {
            background: #ffffff;
            border-radius: 16px;
            box-shadow: 0 20px 25px -5px rgba(0,0,0,0.1), 0 8px 10px -6px rgba(0,0,0,0.1);
            padding: 2rem;
            width: 100%;
            max-width: 28rem;
            text-align: center;
        }
        .brand {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 1rem;
            margin-bottom: 1.5rem;
        }
        .brand img { width: 32px; height: 32px; }
        .brand span {
            font-family: 'Montserrat', sans-serif;
            font-size: 2rem;
            font-weight: 700;
            color: #000;
        }
        h1 {
            font-family: 'Montserrat', sans-serif;
            font-size: 1.5rem;
            font-weight: 700;
            color: #212529;
            margin-bottom: 1rem;
        }
        .icon-wrap {
            width: 64px;
            height: 64px;
            margin: 0 auto 1.25rem;
            background: #eff6ff;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        .icon-wrap svg {
            width: 28px;
            height: 28px;
            stroke: #1e40af;
        }
        .message {
            font-size: 0.9375rem;
            color: #374151;
            line-height: 1.6;
            margin-bottom: 1.5rem;
        }
        .message strong {
            color: #212529;
        }
        .contact-info {
            background: #f8fafc;
            border: 1px solid #e2e8f0;
            border-radius: 8px;
            padding: 1rem;
            margin-bottom: 1.5rem;
            font-size: 0.875rem;
            color: #475569;
            line-height: 1.6;
        }
        .contact-info .step {
            display: flex;
            align-items: flex-start;
            gap: 0.75rem;
            text-align: left;
            margin-bottom: 0.75rem;
        }
        .contact-info .step:last-child { margin-bottom: 0; }
        .contact-info .step-num {
            flex-shrink: 0;
            width: 22px;
            height: 22px;
            background: #1e40af;
            color: #fff;
            border-radius: 50%;
            font-size: 0.75rem;
            font-weight: 700;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        .btn-back {
            display: block;
            width: 100%;
            padding: 1rem 1.5rem;
            background: #1e40af;
            color: #fff;
            border: none;
            border-radius: 8px;
            font-size: 1rem;
            font-weight: 500;
            cursor: pointer;
            transition: background 0.15s;
            text-decoration: none;
            text-align: center;
        }
        .btn-back:hover { background: #1e3a8a; }
        .footer {
            margin-top: 2rem;
            text-align: center;
        }
        .footer span {
            color: #212529;
            font-size: 1rem;
        }
        .footer img {
            display: block;
            margin: 0.5rem auto 0;
            height: 34px;
        }
    </style>
</head>
<body>
    <div class="card">
        <div class="brand">
            <img src="/images/AimLogo-dark.svg" alt="AIM logo" />
            <span>AIM</span>
        </div>

        <div class="icon-wrap">
            <svg fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24">
                <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
                <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
            </svg>
        </div>

        <h1>Forgot your password?</h1>

        <p class="message">
            Contact your administrator to reset your password.
        </p>

        <div class="contact-info">
            <div class="step">
                <span class="step-num">1</span>
                <span>Reach out to your team's AIM administrator via email, Slack, or Teams.</span>
            </div>
            <div class="step">
                <span class="step-num">2</span>
                <span>They'll reset your password and provide a temporary one.</span>
            </div>
            <div class="step">
                <span class="step-num">3</span>
                <span>Sign in with the temporary password, then change it from your <strong>Profile</strong> page.</span>
            </div>
        </div>

        <a href="/Identity/Account/Login" class="btn-back">Back to Sign In</a>
    </div>

    <div class="footer">
        <span>Powered by</span>
        <img src="/images/shieldlytics.png" alt="Shieldlytics" onerror="this.style.display='none'" />
    </div>
</body>
</html>
