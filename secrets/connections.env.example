# secrets/connections.env.example — copy to connections.env and fill in real values
# connections.env is gitignored; this example file IS tracked in git.
#
# Setup:
#   cp secrets/connections.env.example secrets/connections.env
#   # then edit connections.env with real credentials
#
# ── Console tools (IngestCsv, MigrateData) ────────────────────────────────────
# Credential resolution order:
#   1. Environment variable (CI/CD, Docker)
#   2. secrets/connections.env (this file, local dev)
#   3. Fatal error — no silent fallback

AIM_PG_CONN=Host=localhost;Port=5432;Database=aim;Username=aim_user;Password=CHANGEME
AIM_MYSQL_CONN=Server=YOUR_HOST;Port=3307;Database=AIM;User ID=YOUR_USER;Password=CHANGEME;

# ── Web app (AIM.Web) ──────────────────────────────────────────────────────────
# appsettings.json has Password=REPLACE_WITH_ENV_VAR as a safe placeholder.
# For local development, create appsettings.Development.json (gitignored) with:
#
#   {
#     "ConnectionStrings": {
#       "DefaultConnection": "Host=localhost;Port=5432;Database=aim;Username=aim_user;Password=CHANGEME"
#     }
#   }
#
# For production/CI, set the environment variable:
#   ConnectionStrings__DefaultConnection=Host=...;Password=REAL_PASSWORD
