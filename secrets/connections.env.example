# secrets/connections.env.example — copy to connections.env and fill in real values
# connections.env is gitignored; this example file IS tracked in git.
#
# Setup:
#   cp secrets/connections.env.example secrets/connections.env
#   # then edit connections.env with real credentials
#
# ── AIM_FINCEN database ────────────────────────────────────────────────────────
# Credential resolution order for console tools (ImportBsa):
#   1. Environment variable (CI/CD, Docker)
#   2. secrets/connections.env (this file, local dev)
#   3. Fatal error — no silent fallback

AIM_FINCEN_PG_CONN=Host=localhost;Port=5432;Database=aim_fincen;Username=aim_fincen_user;Password=CHANGEME

# ── Web app (AIM.Web) ──────────────────────────────────────────────────────────
# appsettings.json has Password=REPLACE_WITH_USER_SECRETS as a safe placeholder.
# For local development, use dotnet user-secrets (preferred over appsettings.Development.json):
#
#   dotnet user-secrets set "ConnectionStrings:DefaultConnection" \
#     "Host=localhost;Port=5432;Database=aim_fincen;Username=aim_fincen_user;Password=REAL_PASSWORD"
#
# For production/CI, set the environment variable:
#   ConnectionStrings__DefaultConnection=Host=...;Password=REAL_PASSWORD

# ── FinCEN API (stub in dev; live swap later) ──────────────────────────────────
FINCEN_API_URL=https://bsaefiling.fincen.treas.gov/api/v1
FINCEN_API_KEY=CHANGEME
FINCEN_ENABLED=false
