@page
@{
    Layout = null;
    var displayName = User.Identity?.Name ?? "Guest";
    var isAdmin = User.IsInRole("Admin");
    var isAnalyst = User.IsInRole("Analyst") || isAdmin;
}
<!DOCTYPE html>
<html lang="en" class="dark">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>AIM — FinCEN Suspicious Activity Monitor</title>

  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      darkMode: 'class',
      theme: { extend: { fontFamily: { sans: ['Inter', 'ui-sans-serif', 'system-ui', 'sans-serif'] } } }
    }
  </script>

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">

  <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.13.9/dist/cdn.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/apexcharts@3.48.0/dist/apexcharts.min.js"></script>

  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/ag-grid-community@31.3.0/styles/ag-grid.css">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/ag-grid-community@31.3.0/styles/ag-theme-alpine.css">
  <script src="https://cdn.jsdelivr.net/npm/ag-grid-community@31.3.0/dist/ag-grid-community.min.js"></script>

  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
  <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

  <style>
    body { font-family: 'Inter', ui-sans-serif, system-ui, sans-serif; }

    .leaflet-container { background:#0d1321 !important; }
    .leaflet-control-zoom a { background:#1e293b !important; color:#94a3b8 !important; border-color:#334155 !important; }
    .leaflet-bar { border:none !important; box-shadow:0 2px 8px rgba(0,0,0,.5) !important; }
    .leaflet-control-attribution { background:rgba(7,11,22,.8) !important; color:#475569 !important; font-size:10px !important; }
    .leaflet-control-attribution a { color:#60a5fa !important; }

    #sidebar { position:fixed; left:0; top:0; bottom:0; width:232px; background:#0b0f1e; border-right:1px solid #1e293b; display:flex; flex-direction:column; z-index:40; }
    #main    { margin-left:232px; min-height:100vh; background:#070b16; }

    .ag-theme-alpine-dark {
      --ag-background-color:#111827; --ag-header-background-color:#0d1321;
      --ag-odd-row-background-color:#0f1629; --ag-row-hover-color:rgba(59,130,246,.06);
      --ag-selected-row-background-color:rgba(59,130,246,.12); --ag-border-color:#1e293b;
      --ag-header-foreground-color:#475569; --ag-foreground-color:#e2e8f0;
      --ag-font-size:13px; --ag-row-height:44px; --ag-header-height:40px;
      --ag-cell-horizontal-padding:14px; --ag-font-family:'Inter', ui-sans-serif, system-ui, sans-serif;
    }
    .ag-theme-alpine-dark .ag-header-cell-text { font-size:11px; font-weight:600; text-transform:uppercase; letter-spacing:.05em; }
    .ag-theme-alpine-dark .ag-row { border-bottom:1px solid #1e293b; cursor:pointer; }
    .ag-theme-alpine-dark .ag-root-wrapper { border:none; }

    .rb { display:inline-flex; align-items:center; padding:2px 8px; border-radius:9999px; font-size:11px; font-weight:700; text-transform:uppercase; letter-spacing:.05em; white-space:nowrap; }
    .rb-TOP      { background:rgba(239,68,68,.15);  color:#f87171; border:1px solid rgba(239,68,68,.3); }
    .rb-HIGH     { background:rgba(249,115,22,.15); color:#fb923c; border:1px solid rgba(249,115,22,.3); }
    .rb-MODERATE { background:rgba(234,179,8,.15);  color:#fbbf24; border:1px solid rgba(234,179,8,.3); }
    .rb-LOW      { background:rgba(34,197,94,.15);  color:#4ade80; border:1px solid rgba(34,197,94,.3); }

    .sb { display:inline-flex; align-items:center; padding:2px 8px; border-radius:4px; font-size:11px; font-weight:600; white-space:nowrap; }
    .sb-Draft         { background:#1e293b; color:#94a3b8; }
    .sb-PendingReview { background:rgba(234,179,8,.15); color:#fbbf24; }
    .sb-Approved      { background:rgba(14,165,233,.15); color:#38bdf8; }
    .sb-Submitted     { background:rgba(99,102,241,.15); color:#a5b4fc; }
    .sb-Acknowledged  { background:rgba(16,185,129,.15); color:#34d399; }
    .sb-Rejected      { background:rgba(239,68,68,.15); color:#f87171; }

    #drawer { position:fixed; right:0; top:0; bottom:0; width:520px; background:#0f172a; border-left:1px solid #1e293b; z-index:50; display:flex; flex-direction:column; transform:translateX(100%); transition:transform .3s cubic-bezier(.4,0,.2,1); overflow-y:auto; }
    #drawer.open { transform:translateX(0); }
    #backdrop { position:fixed; inset:0; background:rgba(0,0,0,.55); backdrop-filter:blur(2px); z-index:49; opacity:0; pointer-events:none; transition:opacity .3s; }
    #backdrop.open { opacity:1; pointer-events:auto; }

    .nav-item { display:flex; align-items:center; gap:9px; padding:7px 12px; border-radius:7px; cursor:pointer; transition:all .15s; color:#475569; font-size:13px; font-weight:500; }
    .nav-item:hover { background:#1e293b; color:#cbd5e1; }
    .nav-item.active { background:rgba(59,130,246,.12); color:#93c5fd; }
    .tier-btn { display:flex; align-items:center; justify-content:space-between; padding:6px 12px; border-radius:6px; cursor:pointer; transition:all .15s; font-size:12px; font-weight:500; }
    .tier-btn:hover { background:rgba(30,41,59,.4); }

    ::-webkit-scrollbar { width:5px; height:5px; }
    ::-webkit-scrollbar-thumb { background:#334155; border-radius:3px; }
    ::-webkit-scrollbar-track { background:transparent; }
    .tab-btn { padding:8px 12px; font-size:12px; font-weight:500; border-bottom:2px solid transparent; color:#475569; cursor:pointer; }
    .tab-btn.active { border-bottom-color:#3b82f6; color:#60a5fa; }

    .toast-wrap { position:fixed; bottom:24px; right:24px; z-index:100; display:flex; flex-direction:column; gap:8px; }
    .toast { padding:10px 14px; border-radius:8px; font-size:12px; font-weight:500; }
    .toast-info    { background:#0c1a2e; border:1px solid #1e3a5f; color:#93c5fd; }
    .toast-success { background:#052e16; border:1px solid #14532d; color:#86efac; }
    .toast-error   { background:#1c0909; border:1px solid #450a0a; color:#fca5a5; }
  </style>
</head>
<body class="bg-[#070b16] text-slate-100 antialiased">

<div x-data="aim()" x-init="init()">

  <aside id="sidebar">
    <div class="px-4 pt-4 pb-3 border-b border-slate-800">
      <div class="text-xs uppercase tracking-widest text-slate-500">AIM</div>
      <div class="text-sm font-semibold text-slate-200">FinCEN Monitor</div>
    </div>

    <nav class="p-3 flex-1 overflow-y-auto">
      <div class="text-[10px] uppercase tracking-widest text-slate-600 px-2 mb-2">Views</div>
      <template x-for="v in views" :key="v.id">
        <div class="nav-item" :class="{'active': view === v.id}" @@click="setView(v.id)">
          <span x-text="v.label"></span>
        </div>
      </template>

      <div class="text-[10px] uppercase tracking-widest text-slate-600 px-2 mt-5 mb-2">Risk Tier</div>
      <div class="flex flex-col gap-1">
        <div class="tier-btn" :class="{'bg-slate-800': activeRisk === ''}" @@click="setRisk('')">
          <span>All</span>
          <span class="text-slate-500" x-text="kpi.total"></span>
        </div>
        <template x-for="t in ['TOP','HIGH','MODERATE','LOW']" :key="t">
          <div class="tier-btn" :class="{'bg-slate-800': activeRisk === t}" @@click="setRisk(t)">
            <span class="rb" :class="'rb-'+t" x-text="t"></span>
            <span class="text-slate-500" x-text="kpi.byRisk[t] || 0"></span>
          </div>
        </template>
      </div>
    </nav>

    <div class="px-4 py-3 border-t border-slate-800 text-xs">
      <div class="text-slate-400" x-text="'@displayName'"></div>
      <div class="text-slate-600">@(isAdmin ? "Admin" : (isAnalyst ? "Analyst" : "Viewer"))</div>
      <a href="/Identity/Account/Logout" class="text-blue-400 hover:underline text-[11px]">Sign out</a>
    </div>
  </aside>

  <main id="main" class="p-6">
    <div class="flex items-center justify-between mb-5">
      <div>
        <h1 class="text-xl font-semibold">BSA Suspicious Activity Dashboard</h1>
        <p class="text-xs text-slate-500">Adaptive Intelligence Monitor · FinCEN analytics</p>
      </div>
      <div class="flex items-center gap-2">
        <input x-model="search" @@input.debounce.300ms="reload()" type="text"
          placeholder="Search subject name, BSA ID, or form type…"
          class="bg-slate-900 border border-slate-800 rounded-md px-3 py-1.5 text-sm w-80 placeholder-slate-600 focus:outline-none focus:border-blue-500">
        <button @@click="exportCsv()" class="bg-slate-900 hover:bg-slate-800 border border-slate-800 rounded-md px-3 py-1.5 text-xs text-slate-300">Export CSV</button>
        @if (isAnalyst)
        {
          <a href="/Filing" class="bg-blue-600 hover:bg-blue-500 rounded-md px-3 py-1.5 text-xs text-white font-medium">Filing Queue</a>
        }
        @if (isAdmin)
        {
          <a href="/Import" class="bg-slate-900 hover:bg-slate-800 border border-slate-800 rounded-md px-3 py-1.5 text-xs text-slate-300">Bulk Import</a>
        }
      </div>
    </div>

    <div class="grid grid-cols-4 gap-4 mb-5">
      <div class="bg-slate-900 border border-slate-800 rounded-lg p-4">
        <div class="text-[10px] uppercase tracking-widest text-slate-500">Total Filings</div>
        <div class="text-2xl font-semibold mt-1" x-text="kpi.total.toLocaleString()"></div>
      </div>
      <div class="bg-slate-900 border border-slate-800 rounded-lg p-4">
        <div class="text-[10px] uppercase tracking-widest text-slate-500">TOP + HIGH Risk</div>
        <div class="text-2xl font-semibold mt-1 text-orange-400" x-text="((kpi.byRisk.TOP||0)+(kpi.byRisk.HIGH||0)).toLocaleString()"></div>
      </div>
      <div class="bg-slate-900 border border-slate-800 rounded-lg p-4">
        <div class="text-[10px] uppercase tracking-widest text-slate-500">Total Amount Under Suspicion</div>
        <div class="text-2xl font-semibold mt-1" x-text="fmtMoney(kpi.totalAmount)"></div>
      </div>
      <div class="bg-slate-900 border border-slate-800 rounded-lg p-4">
        <div class="text-[10px] uppercase tracking-widest text-slate-500">Amendments</div>
        <div class="text-2xl font-semibold mt-1 text-blue-400" x-text="kpi.amendmentCount.toLocaleString()"></div>
      </div>
    </div>

    <div class="grid grid-cols-2 gap-4 mb-5">
      <div class="bg-slate-900 border border-slate-800 rounded-lg p-4">
        <div class="text-sm font-medium mb-2">Risk Distribution</div>
        <div id="chart-risk"></div>
      </div>
      <div class="bg-slate-900 border border-slate-800 rounded-lg p-4">
        <div class="text-sm font-medium mb-2">Filings by Institution State (top 10)</div>
        <div id="chart-state"></div>
      </div>
    </div>

    <div class="bg-slate-900 border border-slate-800 rounded-lg overflow-hidden">
      <div class="px-4 py-3 border-b border-slate-800 flex items-center justify-between">
        <div class="text-sm font-medium">BSA Filings <span class="text-slate-500 text-xs ml-2" x-text="'('+rows.length+' records)'"></span></div>
      </div>
      <div id="grid" class="ag-theme-alpine-dark" style="height: 520px;"></div>
    </div>

    <div x-show="view==='geographic'" class="bg-slate-900 border border-slate-800 rounded-lg mt-5 p-4">
      <div class="text-sm font-medium mb-3">Geographic Distribution (Institution State)</div>
      <div id="map" style="height:400px; border-radius:6px;"></div>
    </div>
  </main>

  <div id="backdrop" :class="{'open': drawerOpen}" @@click="closeDrawer()"></div>
  <aside id="drawer" :class="{'open': drawerOpen}">
    <div x-show="selected" class="flex flex-col h-full">
      <div class="px-5 py-4 border-b border-slate-800 flex items-start justify-between">
        <div class="flex-1">
          <div class="text-[10px] uppercase tracking-widest text-slate-500">BSA Filing</div>
          <div class="text-lg font-semibold mt-0.5" x-text="selected?.subjectName || '(unnamed subject)'"></div>
          <div class="text-xs text-slate-500 mt-0.5" x-text="'BSA #' + (selected?.bsaId || '—')"></div>
        </div>
        <button @@click="closeDrawer()" class="text-slate-500 hover:text-slate-200 text-xl leading-none">×</button>
      </div>

      <div class="border-b border-slate-800 px-2 flex">
        <template x-for="t in ['overview','transactions','institution','transitions']" :key="t">
          <div class="tab-btn" :class="{active: tab===t}" @@click="tab=t" x-text="t"></div>
        </template>
      </div>

      <div class="flex-1 overflow-y-auto p-5 text-sm">
        <div x-show="tab==='overview'" class="space-y-3">
          <div class="flex items-center gap-3">
            <span class="rb" :class="'rb-'+selected?.riskLevel" x-text="selected?.riskLevel"></span>
            <span class="sb" :class="'sb-'+selected?.status" x-text="selected?.status"></span>
            <span x-show="selected?.isAmendment" class="text-xs text-blue-400">Amendment</span>
          </div>
          <dl class="grid grid-cols-2 gap-y-2 gap-x-4 text-xs">
            <dt class="text-slate-500">Form Type</dt><dd x-text="selected?.formType"></dd>
            <dt class="text-slate-500">Filing Date</dt><dd x-text="fmtDate(selected?.filingDate)"></dd>
            <dt class="text-slate-500">Transaction Date</dt><dd x-text="fmtDate(selected?.transactionDate)"></dd>
            <dt class="text-slate-500">Amount Total</dt><dd x-text="fmtMoney(selected?.amountTotal)"></dd>
            <dt class="text-slate-500">Activity Type</dt><dd x-text="selected?.suspiciousActivityType || '—'"></dd>
            <dt class="text-slate-500">Transaction Type</dt><dd x-text="selected?.transactionType || '—'"></dd>
            <dt class="text-slate-500">Subject State</dt><dd x-text="selected?.subjectState || '—'"></dd>
            <dt class="text-slate-500">Subject DOB</dt><dd x-text="selected?.subjectDob || '—'"></dd>
            <dt class="text-slate-500">EIN/SSN (masked)</dt><dd x-text="maskSsn(selected?.subjectEinSsn)"></dd>
            <dt class="text-slate-500">Zip3</dt><dd x-text="selected?.zip3 || '—'"></dd>
          </dl>
          <div class="mt-4 p-3 rounded-md bg-red-950/30 border border-red-900/40 text-[11px] text-red-300">
            CONFIDENTIAL — SAR disclosure is prohibited under 31 USC 5318(g)(2).
          </div>
          <button @@click="downloadPdf()" class="mt-2 bg-slate-800 hover:bg-slate-700 rounded-md px-3 py-1.5 text-xs">Download PDF</button>
        </div>

        <div x-show="tab==='transactions'" class="space-y-3">
          <div class="text-xs text-slate-500" x-text="'Recent 20 filings for ' + (subjectDetails?.subjectName || '—')"></div>
          <table class="w-full text-xs">
            <thead><tr class="text-slate-500 text-[10px] uppercase tracking-widest">
              <th class="text-left py-1">Date</th>
              <th class="text-left py-1">Form</th>
              <th class="text-right py-1">Amount</th>
              <th class="text-left py-1">Risk</th>
            </tr></thead>
            <tbody>
              <template x-for="t in (subjectDetails?.recentTransactions || [])" :key="t.id">
                <tr class="border-t border-slate-800">
                  <td class="py-1.5" x-text="fmtDate(t.filingDate)"></td>
                  <td x-text="t.formType"></td>
                  <td class="text-right" x-text="fmtMoney(t.amountTotal)"></td>
                  <td><span class="rb" :class="'rb-'+t.riskLevel" x-text="t.riskLevel"></span></td>
                </tr>
              </template>
            </tbody>
          </table>
          <div class="mt-4">
            <div class="text-[10px] uppercase tracking-widest text-slate-500 mb-2">Activity Over Time</div>
            <div id="chart-subject"></div>
          </div>
          <div class="mt-4">
            <div class="text-[10px] uppercase tracking-widest text-slate-500 mb-2">Related Subjects (same EIN/SSN + DOB hash)</div>
            <div x-show="!relatedSubjects.length" class="text-xs text-slate-500">No linked subjects.</div>
            <template x-for="r in relatedSubjects" :key="r.id">
              <div class="text-xs border-t border-slate-800 py-1.5 flex justify-between">
                <span x-text="r.subjectName + ' · ' + r.bsaId"></span>
                <span class="text-slate-500" x-text="fmtDate(r.filingDate)"></span>
              </div>
            </template>
          </div>
        </div>

        <div x-show="tab==='institution'" class="space-y-2 text-xs">
          <dl class="grid grid-cols-2 gap-y-2 gap-x-4">
            <dt class="text-slate-500">Institution Type</dt><dd x-text="selected?.institutionType || '—'"></dd>
            <dt class="text-slate-500">Institution State</dt><dd x-text="selected?.institutionState || '—'"></dd>
            <dt class="text-slate-500">Regulator</dt><dd x-text="selected?.regulator || '—'"></dd>
            <dt class="text-slate-500">Latest Filing</dt><dd x-text="selected?.latestFiling"></dd>
            <dt class="text-slate-500">Receipt Date</dt><dd x-text="fmtDate(selected?.receiptDate)"></dd>
            <dt class="text-slate-500">FinCEN Filing #</dt><dd x-text="selected?.finCenFilingNumber || '—'"></dd>
          </dl>
        </div>

        <div x-show="tab==='transitions'" class="space-y-2">
          <div class="text-xs text-slate-500">Allowed next states based on your role and current status.</div>
          <div class="flex gap-2 flex-wrap">
            <template x-for="nx in legalNext(selected?.status)" :key="nx">
              <button @@click="transition(nx)"
                class="bg-slate-800 hover:bg-slate-700 rounded-md px-3 py-1.5 text-xs"
                x-text="nx"></button>
            </template>
            <div x-show="legalNext(selected?.status).length===0" class="text-xs text-slate-600">No transitions available.</div>
          </div>
        </div>
      </div>
    </div>
  </aside>

  <div class="toast-wrap">
    <template x-for="t in toasts" :key="t.id">
      <div class="toast" :class="'toast-'+t.kind" x-text="t.msg"></div>
    </template>
  </div>
</div>

<script>
  // --- Grid instance lives outside the Alpine component ---
  // Alpine wraps returned state in a Proxy. AG Grid's internal `this` bindings
  // break when its instance is stored inside a Proxy. Keeping `_g` here avoids that.
  let _g = null;
  let _chartRisk = null, _chartState = null, _chartSubject = null, _map = null;

  function aim() {
    return {
      views: [
        {id:'overview', label:'Overview'},
        {id:'filings',  label:'Filings'},
        {id:'subjects', label:'Subjects'},
        {id:'geographic', label:'Geographic'},
      ],
      view: 'overview',
      rows: [],
      activeRisk: '',
      search: '',
      kpi: { total: 0, byRisk: {}, totalAmount: 0, amendmentCount: 0 },
      drawerOpen: false,
      selected: null,
      subjectDetails: null,
      relatedSubjects: [],
      tab: 'overview',
      toasts: [],
      toastId: 0,
      isAdmin: @(isAdmin ? "true" : "false"),
      isAnalyst: @(isAnalyst ? "true" : "false"),

      async init() {
        await this.reload();
        this.buildGrid();
      },

      setView(v) { this.view = v; if (v === 'geographic') this.$nextTick(() => this.ensureMap()); },
      setRisk(r) { this.activeRisk = r; this.reload(); },

      queryString() {
        const p = new URLSearchParams();
        if (this.activeRisk) p.set('riskLevel', this.activeRisk);
        if (this.search) p.set('search', this.search);
        p.set('limit', '1000');
        return p.toString();
      },

      async reload() {
        const qs = this.queryString();
        const [records, summary, risk, states] = await Promise.all([
          fetch('/api/records?' + qs).then(r => r.json()),
          fetch('/api/summary?' + qs).then(r => r.json()),
          fetch('/api/risk-amounts?' + qs).then(r => r.json()),
          fetch('/api/filings-by-state?' + qs).then(r => r.json()),
        ]);
        this.rows = records;
        this.kpi = {
          total: summary.totalReports,
          byRisk: summary.byRiskLevel || {},
          totalAmount: summary.totalAmount || 0,
          amendmentCount: summary.amendmentCount || 0,
        };
        if (_g) _g.setGridOption('rowData', this.rows);
        this.renderCharts(risk, states);
      },

      buildGrid() {
        const el = document.getElementById('grid');
        const defs = [
          { headerName:'Subject', field:'subjectName', flex:1.5, minWidth:160 },
          { headerName:'BSA ID',  field:'bsaId', width:150 },
          { headerName:'Form',    field:'formType', width:90 },
          { headerName:'Filing Date', field:'filingDate', width:120,
            valueFormatter: p => this.fmtDate(p.value) },
          { headerName:'Amount', field:'amountTotal', width:130, type:'rightAligned',
            valueFormatter: p => this.fmtMoney(p.value) },
          { headerName:'Risk', field:'riskLevel', width:110,
            cellRenderer: p => `<span class="rb rb-${p.value}">${p.value}</span>` },
          { headerName:'Status', field:'status', width:130,
            cellRenderer: p => `<span class="sb sb-${p.value}">${p.value}</span>` },
          { headerName:'Inst. State', field:'institutionState', width:100 },
          { headerName:'Regulator', field:'regulator', width:150 },
          { headerName:'Amendment', field:'isAmendment', width:100,
            valueFormatter: p => p.value === true ? '✓' : p.value === false ? '' : '' },
        ];
        _g = agGrid.createGrid(el, {
          columnDefs: defs,
          rowData: this.rows,
          defaultColDef: { sortable:true, resizable:true, filter:true },
          onRowClicked: e => this.openRow(e.data),
          rowSelection: 'single',
        });
      },

      renderCharts(risk, states) {
        const riskColors = { TOP:'#ef4444', HIGH:'#f97316', MODERATE:'#eab308', LOW:'#22c55e' };
        const riskOpts = {
          chart: { type:'donut', height:260, background:'transparent', toolbar:{show:false} },
          series: risk.map(r => r.count),
          labels: risk.map(r => r.riskLevel),
          colors: risk.map(r => riskColors[r.riskLevel] || '#6366f1'),
          legend: { labels: { colors: '#94a3b8' }, position: 'bottom' },
          theme: { mode: 'dark' },
          plotOptions: { pie: { donut: { size:'68%' } } },
          dataLabels: { style: { colors: ['#fff'] } },
          stroke: { colors: ['#0f172a'] },
        };
        const top = states.slice(0, 10);
        const stateOpts = {
          chart: { type:'bar', height:260, background:'transparent', toolbar:{show:false} },
          series: [{ name: 'Filings', data: top.map(s => s.count) }],
          xaxis: { categories: top.map(s => s.state), labels: { style: { colors: '#64748b' } } },
          yaxis: { labels: { style: { colors: '#64748b' } } },
          colors: ['#60a5fa'],
          theme: { mode: 'dark' },
          grid: { borderColor: '#1e293b' },
          plotOptions: { bar: { borderRadius: 3, horizontal: false } },
          dataLabels: { enabled: false },
        };
        if (_chartRisk) _chartRisk.updateOptions(riskOpts, true, true);
        else { _chartRisk = new ApexCharts(document.getElementById('chart-risk'), riskOpts); _chartRisk.render(); }
        if (_chartState) _chartState.updateOptions(stateOpts, true, true);
        else { _chartState = new ApexCharts(document.getElementById('chart-state'), stateOpts); _chartState.render(); }
      },

      ensureMap() {
        if (_map) { setTimeout(() => _map.invalidateSize(), 50); return; }
        _map = L.map('map', { zoomControl: true }).setView([39.5, -98.35], 4);
        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
          attribution: '&copy; OpenStreetMap',
          subdomains: 'abc',
        }).addTo(_map);
        setTimeout(() => _map.invalidateSize(), 50);
      },

      async openRow(r) {
        this.selected = r;
        this.drawerOpen = true;
        this.tab = 'overview';
        this.subjectDetails = null;
        this.relatedSubjects = [];
        if (r.subjectName) {
          const d = await fetch('/api/subject-details?subject=' + encodeURIComponent(r.subjectName)).then(x => x.ok ? x.json() : null);
          this.subjectDetails = d;
          this.renderSubjectChart(d);
          if (d?.linkId) {
            const rel = await fetch('/api/bsa-reports/subjects/' + d.linkId).then(x => x.json());
            this.relatedSubjects = rel.filter(x => x.id !== r.id);
          }
        }
      },

      renderSubjectChart(d) {
        if (!d?.recentTransactions?.length) return;
        const pts = d.recentTransactions
          .filter(t => t.filingDate && t.amountTotal != null)
          .map(t => ({ x: new Date(t.filingDate).getTime(), y: Number(t.amountTotal) }))
          .sort((a, b) => a.x - b.x);
        const opts = {
          chart: { type:'line', height:160, background:'transparent', toolbar:{show:false} },
          series: [{ name: 'Amount', data: pts }],
          xaxis: { type: 'datetime', labels: { style: { colors: '#64748b' } } },
          yaxis: { labels: { style: { colors: '#64748b' }, formatter: v => '$' + Number(v).toLocaleString() } },
          stroke: { curve: 'smooth', width: 2 },
          colors: ['#60a5fa'],
          theme: { mode: 'dark' },
          grid: { borderColor: '#1e293b' },
          dataLabels: { enabled: false },
        };
        this.$nextTick(() => {
          if (_chartSubject) _chartSubject.updateOptions(opts, true, true);
          else { _chartSubject = new ApexCharts(document.getElementById('chart-subject'), opts); _chartSubject.render(); }
        });
      },

      closeDrawer() { this.drawerOpen = false; this.selected = null; },

      legalNext(status) {
        const transitions = {
          Draft: ['PendingReview'],
          PendingReview: this.isAdmin ? ['Approved','Rejected'] : [],
          Approved: this.isAdmin ? ['Submitted'] : [],
          Submitted: [],
          Rejected: ['Draft'],
          Acknowledged: [],
        };
        return transitions[status] || [];
      },

      async transition(target) {
        const id = this.selected?.id;
        if (!id) return;
        const resp = await fetch(`/api/bsa-reports/${id}/transition`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ target, reason: null })
        });
        if (resp.ok) {
          this.selected = await resp.json();
          this.toast('success', `Transitioned to ${target}`);
          this.reload();
        } else {
          const err = await resp.json().catch(() => ({ error: resp.statusText }));
          this.toast('error', err.error || 'Transition failed');
        }
      },

      async downloadPdf() {
        if (!this.selected?.id) return;
        window.location.href = `/api/bsa-reports/${this.selected.id}/export.pdf`;
      },

      exportCsv() {
        window.location.href = '/api/bsa-reports/export.csv?' + this.queryString();
      },

      toast(kind, msg) {
        const id = ++this.toastId;
        this.toasts.push({ id, kind, msg });
        setTimeout(() => this.toasts = this.toasts.filter(t => t.id !== id), 3500);
      },

      fmtMoney(m) {
        if (m == null) return '—';
        const n = Number(m);
        if (!isFinite(n)) return '—';
        return '$' + n.toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 });
      },
      fmtDate(d) {
        if (!d) return '—';
        const t = new Date(d);
        if (isNaN(t)) return '—';
        return t.toISOString().slice(0, 10);
      },
      maskSsn(s) {
        if (!s) return '—';
        if (s.length <= 4) return '*'.repeat(s.length);
        return '*'.repeat(s.length - 4) + s.slice(-4);
      },
    };
  }
</script>

</body>
</html>
