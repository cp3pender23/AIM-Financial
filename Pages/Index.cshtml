@page
@{ Layout = null; }
<!DOCTYPE html>
<html lang="en" class="dark">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>AIM — Adaptive Intelligence Monitor</title>

  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      darkMode: 'class',
      theme: { extend: { fontFamily: { sans: ['Inter', 'ui-sans-serif', 'system-ui', 'sans-serif'] } } }
    }
  </script>

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">

  <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.13.9/dist/cdn.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/apexcharts@3.48.0/dist/apexcharts.min.js"></script>

  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/ag-grid-community@31.3.0/styles/ag-grid.css">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/ag-grid-community@31.3.0/styles/ag-theme-alpine.css">
  <script src="https://cdn.jsdelivr.net/npm/ag-grid-community@31.3.0/dist/ag-grid-community.min.js"></script>

  <script src="https://unpkg.com/lucide@0.344.0/dist/umd/lucide.min.js"></script>

  <!-- Leaflet — free mapping, no API key required -->
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
  <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

  <style>
    body { font-family: 'Inter', ui-sans-serif, system-ui, sans-serif; }

    /* ── Leaflet dark theme ── */
    .leaflet-container { background:#0d1321 !important; }
    .leaflet-control-zoom a { background:#1e293b !important; color:#94a3b8 !important; border-color:#334155 !important; }
    .leaflet-control-zoom a:hover { background:#334155 !important; color:#e2e8f0 !important; }
    .leaflet-bar { border:none !important; box-shadow:0 2px 8px rgba(0,0,0,.5) !important; }
    .leaflet-control-attribution { background:rgba(7,11,22,.8) !important; color:#475569 !important; font-size:10px !important; }
    .leaflet-control-attribution a { color:#60a5fa !important; }

    /* ── Layout ── */
    #sidebar { position:fixed; left:0; top:0; bottom:0; width:232px; background:#0b0f1e; border-right:1px solid #1e293b; display:flex; flex-direction:column; z-index:40; }
    #main    { margin-left:232px; min-height:100vh; background:#070b16; }
    #main.geo-active { height:100vh; overflow:hidden; }

    /* ── AG Grid dark ── */
    .ag-theme-alpine-dark {
      --ag-background-color:#111827;
      --ag-header-background-color:#0d1321;
      --ag-odd-row-background-color:#0f1629;
      --ag-row-hover-color:rgba(59,130,246,.06);
      --ag-selected-row-background-color:rgba(59,130,246,.12);
      --ag-border-color:#1e293b;
      --ag-header-foreground-color:#475569;
      --ag-foreground-color:#e2e8f0;
      --ag-font-size:13px;
      --ag-row-height:48px;
      --ag-header-height:40px;
      --ag-cell-horizontal-padding:14px;
      --ag-font-family:'Inter', ui-sans-serif, system-ui, sans-serif;
    }
    .ag-theme-alpine-dark .ag-header-cell-text { font-size:11px; font-weight:600; text-transform:uppercase; letter-spacing:.05em; }
    .ag-theme-alpine-dark .ag-row { border-bottom:1px solid #1e293b; cursor:pointer; }
    .ag-theme-alpine-dark .ag-root-wrapper { border:none; }

    /* ── Risk badges ── */
    .rb { display:inline-flex; align-items:center; padding:2px 8px; border-radius:9999px; font-size:11px; font-weight:700; text-transform:uppercase; letter-spacing:.05em; white-space:nowrap; }
    .rb-TOP      { background:rgba(239,68,68,.15);  color:#f87171; border:1px solid rgba(239,68,68,.3); }
    .rb-HIGH     { background:rgba(249,115,22,.15); color:#fb923c; border:1px solid rgba(249,115,22,.3); }
    .rb-MODERATE { background:rgba(234,179,8,.15);  color:#fbbf24; border:1px solid rgba(234,179,8,.3); }
    .rb-LOW      { background:rgba(34,197,94,.15);  color:#4ade80; border:1px solid rgba(34,197,94,.3); }

    /* ── Score bar ── */
    .sbar { display:flex; align-items:center; gap:7px; width:100%; }
    .sbar-track { flex:1; height:4px; background:#1e293b; border-radius:2px; overflow:hidden; }
    .sbar-fill  { height:100%; border-radius:2px; background:linear-gradient(90deg,#3b82f6,#818cf8); }

    /* ── Drawer ── */
    #drawer { position:fixed; right:0; top:0; bottom:0; width:472px; background:#0f172a; border-left:1px solid #1e293b; z-index:50; display:flex; flex-direction:column; transform:translateX(100%); transition:transform .3s cubic-bezier(.4,0,.2,1); }
    #drawer.open { transform:translateX(0); }
    #backdrop { position:fixed; inset:0; background:rgba(0,0,0,.55); backdrop-filter:blur(2px); z-index:49; opacity:0; pointer-events:none; transition:opacity .3s; }
    #backdrop.open { opacity:1; pointer-events:auto; }

    /* ── Toast ── */
    #toasts { position:fixed; bottom:24px; right:24px; z-index:100; display:flex; flex-direction:column; gap:8px; pointer-events:none; }
    .toast { display:flex; align-items:center; gap:8px; padding:10px 14px; border-radius:8px; font-size:12px; font-weight:500; animation:slideUp .25s ease; pointer-events:auto; }
    .toast-success { background:#052e16; border:1px solid #14532d; color:#86efac; }
    .toast-info    { background:#0c1a2e; border:1px solid #1e3a5f; color:#93c5fd; }
    .toast-warn    { background:#1c1003; border:1px solid #451a03; color:#fcd34d; }
    .toast-error   { background:#1c0909; border:1px solid #450a0a; color:#fca5a5; }
    @@keyframes slideUp { from{transform:translateY(12px);opacity:0} to{transform:translateY(0);opacity:1} }

    /* ── Nav / tier buttons ── */
    .nav-item { display:flex; align-items:center; gap:9px; padding:7px 12px; border-radius:7px; cursor:pointer; transition:all .15s; color:#475569; font-size:13px; font-weight:500; }
    .nav-item:hover   { background:#1e293b; color:#cbd5e1; }
    .nav-item.active  { background:rgba(59,130,246,.12); color:#93c5fd; }
    .tier-btn { display:flex; align-items:center; justify-content:space-between; padding:6px 12px; border-radius:6px; cursor:pointer; transition:all .15s; font-size:12px; font-weight:500; }
    .tier-btn:hover { background:rgba(30,41,59,.4); }

    /* ── Misc ── */
    .pulse { width:7px; height:7px; border-radius:50%; animation:pulse 2s infinite; }
    @@keyframes pulse { 0%,100%{opacity:1} 50%{opacity:.35} }
    ::-webkit-scrollbar { width:5px; height:5px; }
    ::-webkit-scrollbar-track { background:transparent; }
    ::-webkit-scrollbar-thumb { background:#334155; border-radius:3px; }
    .tab-btn { padding:8px 12px; font-size:12px; font-weight:500; border-bottom:2px solid transparent; color:#475569; transition:all .15s; cursor:pointer; }
    .tab-btn.active { border-bottom-color:#3b82f6; color:#60a5fa; }
    .tab-btn:hover:not(.active) { color:#94a3b8; }
  </style>

</head>
<body class="bg-[#070b16] text-slate-100 antialiased">

<div x-data="aim()"
     @@keydown.window.prevent.slash="focusSearch()"
     @@keydown.window.escape="closeDrawer()"
     @@keydown.window.t="toggleRisk('TOP')"
     @@keydown.window.h="toggleRisk('HIGH')"
     @@keydown.window.m="toggleRisk('MODERATE')"
     @@keydown.window.l="toggleRisk('LOW')"
     @@keydown.window.a="toggleRisk('')">

  <!-- ════════════════════════════ SIDEBAR ════════════════════════════ -->
  <aside id="sidebar">
    <div class="px-4 pt-4 pb-3 border-b border-slate-800">
      <div class="flex items-center gap-2.5">
        <div class="w-8 h-8 rounded-lg bg-blue-600 flex items-center justify-center flex-shrink-0 shadow-lg shadow-blue-900/40">
          <i data-lucide="shield" class="w-4 h-4 text-white"></i>
        </div>
        <div>
          <div class="text-sm font-bold tracking-wide text-white">AIM</div>
          <div class="text-[10px] text-slate-500 -mt-0.5 leading-tight">Adaptive Intelligence Monitor</div>
        </div>
        <div class="ml-auto flex items-center gap-1 text-[10px] text-slate-600">
          <span class="pulse bg-green-500"></span>
        </div>
      </div>
    </div>

    <div class="px-3 pt-3 space-y-0.5">
      <p class="text-[10px] font-semibold text-slate-700 uppercase tracking-widest px-3 mb-1.5">Views</p>
      <div @@click="navTo('overview')" :class="currentView==='overview' ? 'active' : ''" class="nav-item">
        <i data-lucide="layout-dashboard" class="w-4 h-4 flex-shrink-0"></i><span>Overview</span>
      </div>
      <div @@click="navTo('risk')" :class="currentView==='risk' ? 'active' : ''" class="nav-item">
        <i data-lucide="alert-triangle" class="w-4 h-4 flex-shrink-0"></i><span>Risk Intelligence</span>
        <span class="ml-auto text-[10px] bg-red-950 text-red-400 px-1.5 py-0.5 rounded-full"
              x-text="(kpi.topCount + kpi.highCount) || ''"></span>
      </div>
      <div @@click="navTo('products')" :class="currentView==='products' ? 'active' : ''" class="nav-item">
        <i data-lucide="package" class="w-4 h-4 flex-shrink-0"></i><span>Products</span>
      </div>
      <div @@click="navTo('geographic')" :class="currentView==='geographic' ? 'active' : ''" class="nav-item">
        <i data-lucide="map-pin" class="w-4 h-4 flex-shrink-0"></i><span>Geographic</span>
      </div>
      <div @@click="navTo('reports')" :class="currentView==='reports' ? 'active' : ''" class="nav-item">
        <i data-lucide="file-bar-chart" class="w-4 h-4 flex-shrink-0"></i><span>Reports</span>
      </div>
    </div>

    <div class="px-3 mt-5">
      <p class="text-[10px] font-semibold text-slate-700 uppercase tracking-widest px-3 mb-1.5">Risk Tier Filter</p>
      <div class="space-y-0.5">
        <div @@click="toggleRisk('')"
             :class="activeRisks.length === 0 ? 'bg-slate-800 text-slate-200' : 'text-slate-500 hover:text-slate-300'"
             class="tier-btn">
          <span class="flex items-center gap-2"><span class="w-2 h-2 rounded-full bg-blue-500"></span>All</span>
          <span class="text-xs text-slate-600" x-text="kpi.total"></span>
        </div>
        <div @@click="toggleRisk('TOP')"
             :class="activeRisks.includes('TOP') ? 'bg-red-950/60 text-red-300 ring-1 ring-red-800/40' : 'text-slate-500 hover:text-slate-300'"
             class="tier-btn">
          <span class="flex items-center gap-2"><span class="w-2 h-2 rounded-full bg-red-500"></span>TOP</span>
          <span class="text-xs" :class="activeRisks.includes('TOP')?'text-red-400':'text-slate-600'" x-text="kpi.topCount"></span>
        </div>
        <div @@click="toggleRisk('HIGH')"
             :class="activeRisks.includes('HIGH') ? 'bg-orange-950/60 text-orange-300 ring-1 ring-orange-800/40' : 'text-slate-500 hover:text-slate-300'"
             class="tier-btn">
          <span class="flex items-center gap-2"><span class="w-2 h-2 rounded-full bg-orange-500"></span>HIGH</span>
          <span class="text-xs" :class="activeRisks.includes('HIGH')?'text-orange-400':'text-slate-600'" x-text="kpi.highCount"></span>
        </div>
        <div @@click="toggleRisk('MODERATE')"
             :class="activeRisks.includes('MODERATE') ? 'bg-amber-950/60 text-amber-300 ring-1 ring-amber-800/40' : 'text-slate-500 hover:text-slate-300'"
             class="tier-btn">
          <span class="flex items-center gap-2"><span class="w-2 h-2 rounded-full bg-amber-500"></span>MODERATE</span>
          <span class="text-xs" :class="activeRisks.includes('MODERATE')?'text-amber-400':'text-slate-600'" x-text="kpi.moderateCount"></span>
        </div>
        <div @@click="toggleRisk('LOW')"
             :class="activeRisks.includes('LOW') ? 'bg-green-950/60 text-green-300 ring-1 ring-green-800/40' : 'text-slate-500 hover:text-slate-300'"
             class="tier-btn">
          <span class="flex items-center gap-2"><span class="w-2 h-2 rounded-full bg-green-500"></span>LOW</span>
          <span class="text-xs" :class="activeRisks.includes('LOW')?'text-green-400':'text-slate-600'" x-text="kpi.lowCount"></span>
        </div>
      </div>
    </div>

    <div class="mt-auto px-4 pb-4 pt-3 border-t border-slate-800">
      <p class="text-[10px] text-slate-700 mb-1.5 font-medium">Keyboard shortcuts</p>
      <div class="space-y-0.5 text-[10px] text-slate-600">
        <div class="flex justify-between"><span>Search</span><kbd class="bg-slate-800 text-slate-500 px-1.5 rounded text-[9px]">/</kbd></div>
        <div class="flex justify-between"><span>Filter risk</span><kbd class="bg-slate-800 text-slate-500 px-1.5 rounded text-[9px]">T H M L A</kbd></div>
        <div class="flex justify-between"><span>Close panel</span><kbd class="bg-slate-800 text-slate-500 px-1.5 rounded text-[9px]">Esc</kbd></div>
      </div>
    </div>
  </aside>

  <!-- ════════════════════════════ MAIN ════════════════════════════ -->
  <main id="main" :class="currentView === 'geographic' ? 'geo-active' : ''">

    <!-- Top bar -->
    <div class="sticky top-0 z-30 flex items-center gap-3 px-6 h-12 border-b border-slate-800/70 bg-[#070b16]/90 backdrop-blur-sm">
      <div class="text-xs text-slate-500">
        <span class="text-slate-300 font-medium" x-text="{'overview':'Overview','risk':'Risk Intelligence','products':'Products','geographic':'Geographic','reports':'Reports'}[currentView]"></span>
        <template x-if="activeRisks.length > 0">
          <span> / <span class="text-slate-400" x-text="activeRisks.join(' + ') + ' Risk'"></span></span>
        </template>
      </div>
      <div class="flex-1"></div>
      <div class="relative">
        <i data-lucide="search" class="w-3.5 h-3.5 text-slate-600 absolute left-2.5 top-1/2 -translate-y-1/2 pointer-events-none"></i>
        <input id="grid-search" type="text" placeholder="Search vendors… ( / )"
               x-model="searchQuery" @@input.debounce.250ms="applySearch()"
               class="w-52 bg-slate-800/70 border border-slate-700 text-slate-200 text-xs rounded-lg pl-8 pr-3 py-1.5 placeholder-slate-600 focus:outline-none focus:ring-1 focus:ring-blue-500 transition" />
      </div>
      <button @@click="refreshData()" class="flex items-center gap-1.5 text-xs text-slate-400 hover:text-slate-100 bg-slate-800 hover:bg-slate-700 px-3 py-1.5 rounded-lg border border-slate-700 transition">
        <span class="inline-flex" :class="loading ? 'animate-spin' : ''"><i data-lucide="refresh-cw" class="w-3.5 h-3.5"></i></span> Refresh
      </button>
      <button @@click="exportCsv()" class="flex items-center gap-1.5 text-xs text-slate-400 hover:text-slate-100 bg-slate-800 hover:bg-slate-700 px-3 py-1.5 rounded-lg border border-slate-700 transition">
        <i data-lucide="download" class="w-3.5 h-3.5"></i> Export
      </button>
    </div>

    <div x-show="currentView !== 'geographic' && currentView !== 'reports'" class="px-6 py-5 space-y-5">

      <!-- Health Banner -->
      <div class="relative overflow-hidden rounded-xl border border-blue-900/30 bg-gradient-to-r from-blue-950/50 via-[#0d1a35]/60 to-transparent p-4 flex items-center gap-5">
        <div class="text-center flex-shrink-0">
          <div class="text-4xl font-black text-white tabular-nums" x-text="healthScore + '%'">—</div>
          <div class="text-[10px] font-bold uppercase tracking-widest text-blue-400 mt-0.5">Brand Protection Index <span class="text-slate-600 font-normal normal-case tracking-normal">(global)</span></div>
        </div>
        <div class="w-px self-stretch bg-blue-900/50 flex-shrink-0"></div>
        <div class="text-xs text-slate-400 max-w-xs leading-relaxed">
          Vendors at <span class="text-green-400 font-semibold">LOW</span> or <span class="text-amber-400 font-semibold">MODERATE</span> risk across the full dataset. Always global — unaffected by tier filter. Target above 70%.
        </div>
        <div class="ml-auto flex-shrink-0 flex items-center gap-1.5 text-xs text-slate-500">
          <span class="pulse bg-green-500"></span> Live
        </div>
        <div class="absolute -right-6 -top-6 w-28 h-28 bg-blue-600/5 rounded-full blur-2xl pointer-events-none"></div>
      </div>

      <!-- KPI Cards -->
      <div class="grid grid-cols-4 gap-4">
        <div class="bg-slate-900 border border-slate-800 rounded-xl p-4 overflow-hidden">
          <div class="flex items-start justify-between">
            <div>
              <p class="text-[11px] font-semibold text-slate-500 uppercase tracking-wide">Total Vendors</p>
              <p class="text-2xl font-bold text-white mt-1 tabular-nums" x-text="loading ? '—' : view.total.toLocaleString()"></p>
            </div>
            <div class="w-8 h-8 rounded-lg bg-blue-900/40 flex items-center justify-center flex-shrink-0">
              <i data-lucide="users" class="w-4 h-4 text-blue-400"></i>
            </div>
          </div>
          <div id="sp-total" class="mt-2 -mx-1" style="height:38px"></div>
          <p class="text-[11px] text-slate-600 mt-1">Across all risk tiers</p>
        </div>

        <div class="bg-slate-900 border border-slate-800 rounded-xl p-4 overflow-hidden">
          <div class="flex items-start justify-between">
            <div>
              <p class="text-[11px] font-semibold text-slate-500 uppercase tracking-wide">TOP + HIGH Risk</p>
              <p class="text-2xl font-bold text-red-400 mt-1 tabular-nums" x-text="loading ? '—' : view.highRisk.toLocaleString()"></p>
            </div>
            <div class="w-8 h-8 rounded-lg bg-red-900/40 flex items-center justify-center flex-shrink-0">
              <i data-lucide="alert-triangle" class="w-4 h-4 text-red-400"></i>
            </div>
          </div>
          <div id="sp-high" class="mt-2 -mx-1" style="height:38px"></div>
          <p class="text-[11px] text-slate-600 mt-1">Require immediate review</p>
        </div>

        <div class="bg-slate-900 border border-slate-800 rounded-xl p-4 overflow-hidden">
          <div class="flex items-start justify-between">
            <div>
              <p class="text-[11px] font-semibold text-slate-500 uppercase tracking-wide">Products Tracked</p>
              <p class="text-2xl font-bold text-white mt-1 tabular-nums" x-text="loading ? '—' : view.products.toLocaleString()"></p>
            </div>
            <div class="w-8 h-8 rounded-lg bg-purple-900/40 flex items-center justify-center flex-shrink-0">
              <i data-lucide="package" class="w-4 h-4 text-purple-400"></i>
            </div>
          </div>
          <div id="sp-products" class="mt-2 -mx-1" style="height:38px"></div>
          <p class="text-[11px] text-slate-600 mt-1">Distinct product SKUs</p>
        </div>

        <div class="bg-slate-900 border border-slate-800 rounded-xl p-4 overflow-hidden">
          <div class="flex items-start justify-between">
            <div>
              <p class="text-[11px] font-semibold text-slate-500 uppercase tracking-wide">Unverified Sellers</p>
              <p class="text-2xl font-bold text-amber-400 mt-1 tabular-nums" x-text="loading ? '—' : view.unverified.toLocaleString()"></p>
            </div>
            <div class="w-8 h-8 rounded-lg bg-amber-900/40 flex items-center justify-center flex-shrink-0">
              <i data-lucide="shield-off" class="w-4 h-4 text-amber-400"></i>
            </div>
          </div>
          <div id="sp-unverified" class="mt-2 -mx-1" style="height:38px"></div>
          <p class="text-[11px] text-slate-600 mt-1">No verified company status</p>
        </div>
      </div>

      <!-- Charts Row -->
      <div class="grid grid-cols-5 gap-4">
        <div class="col-span-2 bg-slate-900 border border-slate-800 rounded-xl p-4">
          <p class="text-sm font-semibold text-slate-200">Risk Distribution</p>
          <p class="text-xs text-slate-500 mt-0.5 mb-3">Vendor count by tier</p>
          <div id="chart-donut" style="height:190px"></div>
        </div>
        <div class="col-span-3 bg-slate-900 border border-slate-800 rounded-xl p-4">
          <p class="text-sm font-semibold text-slate-200">Annual Sales by State</p>
          <p class="text-xs text-slate-500 mt-0.5 mb-3">Top 10 states by revenue</p>
          <div id="chart-states" style="height:190px"></div>
        </div>
      </div>

      <!-- Grid Panel -->
      <div class="bg-slate-900 border border-slate-800 rounded-xl overflow-hidden">
        <div class="flex items-center justify-between px-4 py-2.5 border-b border-slate-800">
          <div class="flex items-center gap-2.5">
            <span class="text-sm font-semibold text-slate-200">Vendor Intelligence</span>
            <span class="text-[11px] bg-slate-800 text-slate-400 px-2 py-0.5 rounded-full tabular-nums"
                  x-text="rowCount + ' records'"></span>
          </div>
          <div x-show="selected.length > 0"
               x-transition:enter="transition duration-150"
               x-transition:enter-start="opacity-0 -translate-y-1"
               x-transition:enter-end="opacity-100 translate-y-0"
               class="flex items-center gap-2 text-xs bg-amber-950/40 border border-amber-900/40 text-amber-300 px-3 py-1.5 rounded-lg">
            <i data-lucide="check-square" class="w-3.5 h-3.5"></i>
            <span x-text="selected.length + ' selected'"></span>
            <button @@click="bulkFlag()" class="underline hover:text-amber-100 ml-1">Flag for review</button>
            <button @@click="clearSel()" class="text-slate-500 hover:text-slate-300 ml-1">✕</button>
          </div>
        </div>
        <div id="vendor-grid" class="ag-theme-alpine-dark" style="height:500px;width:100%"></div>
      </div>

    </div>

    <!-- ══════════════════════════ GEOGRAPHIC VIEW ══════════════════════════ -->
    <div x-show="currentView === 'geographic'" style="display:none" class="flex">

      <!-- Map — explicit pixel height so Leaflet never sees clientHeight=0 -->
      <div class="flex-1 relative bg-[#0d1321]" style="height:calc(100vh - 48px)">
        <div x-show="geoLoading" class="absolute inset-0 z-20 flex items-center justify-center bg-[#0d1321]/80 backdrop-blur-sm">
          <div class="flex items-center gap-3 text-sm text-slate-300 bg-slate-900 border border-slate-700 px-5 py-3 rounded-xl shadow-xl">
