@page
@{
    Layout = null;
    var isAdmin = User.IsInRole("Admin");
    var isAnalyst = User.IsInRole("Analyst") || isAdmin;
    if (!isAnalyst) { Response.Redirect("/"); return; }
}
<!DOCTYPE html>
<html lang="en" class="dark">
<head>
  <meta charset="UTF-8" />
  <title>AIM — Filing Queue</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.13.9/dist/cdn.min.js"></script>
  <style>
    body { background:#070b16; color:#e2e8f0; font-family: ui-sans-serif, system-ui, sans-serif; }
    .sb { display:inline-flex; padding:2px 8px; border-radius:4px; font-size:11px; font-weight:600; }
    .sb-Draft{background:#1e293b;color:#94a3b8} .sb-PendingReview{background:rgba(234,179,8,.15);color:#fbbf24}
    .sb-Approved{background:rgba(14,165,233,.15);color:#38bdf8} .sb-Submitted{background:rgba(99,102,241,.15);color:#a5b4fc}
    .sb-Acknowledged{background:rgba(16,185,129,.15);color:#34d399} .sb-Rejected{background:rgba(239,68,68,.15);color:#f87171}
  </style>
</head>
<body x-data="filingQueue()" x-init="init()">
  <div class="max-w-6xl mx-auto p-6">
    <div class="flex items-center justify-between mb-5">
      <div>
        <h1 class="text-xl font-semibold">Filing Queue</h1>
        <p class="text-xs text-slate-500">Drafts, reviews, and submissions</p>
      </div>
      <div class="flex items-center gap-2">
        <a href="/" class="text-blue-400 text-xs hover:underline">← Dashboard</a>
        <button @@click="showNew = !showNew"
          class="bg-blue-600 hover:bg-blue-500 rounded-md px-3 py-1.5 text-xs text-white font-medium">+ New Filing</button>
      </div>
    </div>

    <div class="flex gap-2 mb-4">
      <template x-for="s in statuses" :key="s">
        <button @@click="status = s; load()" class="px-3 py-1.5 text-xs rounded-md"
          :class="status === s ? 'bg-blue-600 text-white' : 'bg-slate-900 text-slate-300 border border-slate-800'"
          x-text="s"></button>
      </template>
    </div>

    <div x-show="showNew" class="bg-slate-900 border border-slate-800 rounded-lg p-4 mb-5">
      <div class="text-sm font-medium mb-3">New Draft Filing</div>
      <div class="grid grid-cols-2 gap-3 text-xs">
        <label class="flex flex-col">Form Type <input x-model="draft.formType" class="bg-slate-800 border border-slate-700 rounded px-2 py-1.5 mt-1"></label>
        <label class="flex flex-col">BSA ID <input x-model="draft.bsaId" class="bg-slate-800 border border-slate-700 rounded px-2 py-1.5 mt-1"></label>
        <label class="flex flex-col">Subject Name <input x-model="draft.subjectName" class="bg-slate-800 border border-slate-700 rounded px-2 py-1.5 mt-1"></label>
        <label class="flex flex-col">Subject State <input x-model="draft.subjectState" class="bg-slate-800 border border-slate-700 rounded px-2 py-1.5 mt-1" maxlength="2"></label>
        <label class="flex flex-col">Subject DOB <input x-model="draft.subjectDob" class="bg-slate-800 border border-slate-700 rounded px-2 py-1.5 mt-1" placeholder="YYYY-MM-DD"></label>
        <label class="flex flex-col">EIN/SSN <input x-model="draft.subjectEinSsn" class="bg-slate-800 border border-slate-700 rounded px-2 py-1.5 mt-1"></label>
        <label class="flex flex-col">Amount <input type="number" step="0.01" x-model.number="draft.amountTotal" class="bg-slate-800 border border-slate-700 rounded px-2 py-1.5 mt-1"></label>
        <label class="flex flex-col">Suspicious Activity Type <input x-model="draft.suspiciousActivityType" class="bg-slate-800 border border-slate-700 rounded px-2 py-1.5 mt-1"></label>
        <label class="flex flex-col">Transaction Type <input x-model="draft.transactionType" class="bg-slate-800 border border-slate-700 rounded px-2 py-1.5 mt-1"></label>
        <label class="flex flex-col">Transaction Date <input type="date" x-model="draft.transactionDate" class="bg-slate-800 border border-slate-700 rounded px-2 py-1.5 mt-1"></label>
        <label class="flex flex-col">Institution Type <input x-model="draft.institutionType" class="bg-slate-800 border border-slate-700 rounded px-2 py-1.5 mt-1"></label>
        <label class="flex flex-col">Institution State <input x-model="draft.institutionState" class="bg-slate-800 border border-slate-700 rounded px-2 py-1.5 mt-1" maxlength="2"></label>
        <label class="flex flex-col col-span-2">Regulator <input x-model="draft.regulator" class="bg-slate-800 border border-slate-700 rounded px-2 py-1.5 mt-1"></label>
      </div>
      <div class="mt-3 flex gap-2">
        <button @@click="createDraft()" class="bg-blue-600 hover:bg-blue-500 rounded-md px-3 py-1.5 text-xs text-white">Save Draft</button>
        <button @@click="showNew=false" class="bg-slate-800 rounded-md px-3 py-1.5 text-xs">Cancel</button>
        <span class="text-xs text-red-400" x-text="formError"></span>
      </div>
    </div>

    <div class="bg-slate-900 border border-slate-800 rounded-lg overflow-hidden">
      <table class="w-full text-xs">
        <thead class="bg-slate-950 text-slate-500 uppercase text-[10px] tracking-widest">
          <tr><th class="text-left p-3">BSA ID</th><th class="text-left p-3">Subject</th><th class="text-left p-3">Form</th><th class="text-right p-3">Amount</th><th class="text-left p-3">Risk</th><th class="text-left p-3">Status</th><th class="text-left p-3">Updated</th></tr>
        </thead>
        <tbody>
          <template x-for="r in rows" :key="r.id">
            <tr class="border-t border-slate-800 hover:bg-slate-800/30 cursor-pointer" @@click="openDetails(r)">
              <td class="p-3" x-text="r.bsaId"></td>
              <td class="p-3" x-text="r.subjectName || '—'"></td>
              <td class="p-3" x-text="r.formType"></td>
              <td class="p-3 text-right" x-text="r.amountTotal != null ? '$'+Number(r.amountTotal).toLocaleString() : '—'"></td>
              <td class="p-3" x-text="r.riskLevel"></td>
              <td class="p-3"><span class="sb" :class="'sb-'+r.status" x-text="r.status"></span></td>
              <td class="p-3 text-slate-500" x-text="new Date(r.updatedAt).toISOString().slice(0,10)"></td>
            </tr>
          </template>
          <tr x-show="!rows.length"><td colspan="7" class="p-6 text-center text-slate-600">No filings in this status.</td></tr>
        </tbody>
      </table>
    </div>
  </div>

<script>
  function filingQueue() {
    return {
      statuses: ['Draft','PendingReview','Approved','Submitted','Rejected','Acknowledged'],
      status: 'Draft',
      rows: [],
      showNew: false,
      draft: { formType:'BSAR', bsaId:'', subjectName:'', subjectState:'', subjectDob:'', subjectEinSsn:'',
               amountTotal:null, suspiciousActivityType:'', transactionType:'', transactionDate:null,
               institutionType:'', institutionState:'', regulator:'' },
      formError: '',
      async init() { await this.load(); },
      async load() {
        const r = await fetch('/api/bsa-reports/queue?status=' + this.status);
        this.rows = await r.json();
      },
      async createDraft() {
        this.formError = '';
        const r = await fetch('/api/bsa-reports', { method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify(this.draft) });
        if (!r.ok) { this.formError = (await r.json().catch(()=>({error:r.statusText}))).error || r.statusText; return; }
        this.showNew = false;
        this.draft.bsaId = ''; this.draft.subjectName = ''; this.draft.amountTotal = null;
        this.status = 'Draft';
        await this.load();
      },
      openDetails(r) { window.location.href = '/#filing-' + r.id; }
    };
  }
</script>
</body>
</html>
